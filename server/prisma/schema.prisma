generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String?
  createdAt    DateTime      @default(now())
  profile      Profile?
  answers      CommonAnswer[]
  applications Application[]
  preference   JobPreference?
  matchHistory JobMatchHistory[]
}

model Profile {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName    String  @default("")
  lastName     String  @default("")
  phone        String?
  address      String?
  city         String?
  state        String?
  zip          String?
  country      String  @default("US")
  linkedinUrl  String?
  portfolioUrl String?
  resumePath       String?
  resumeText       String?
  bio              String?
  linkedinEmail    String?
  linkedinPassword String?
}

model CommonAnswer {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  question String
  answer   String
}

model Job {
  id           String        @id @default(cuid())
  externalId   String        @unique
  title        String
  company      String
  location     String?
  description  String
  url          String
  source       String
  salary       String?
  jobType      String?
  isRemote     Boolean       @default(false)
  postedAt     DateTime?
  fetchedAt    DateTime      @default(now())
  applications Application[]
}

model Application {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId        String
  job          Job               @relation(fields: [jobId], references: [id])
  status       ApplicationStatus @default(PENDING)
  matchScore   Float?
  appliedAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  notes        String?
  errorMessage String?
}

model JobPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords       String   @default("")
  location       String   @default("")
  dailyEmailTime String   @default("09:00")
  emailEnabled   Boolean  @default(false)
  updatedAt      DateTime @updatedAt
}

model JobMatchHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  runDate    DateTime @default(now())
  jobLinks   String[]
  topMatches Json
}

enum ApplicationStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  FAILED
  INTERVIEWING
  REJECTED
  OFFER
}
